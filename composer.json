{
  "name": "joeri-abbo/laravel-api-markdown-tree",
  "description": "A Laravel package to generate a tree view of API routes in Markdown format.",
  "type": "library",
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "JoeriAbbo\\LaravelApiMarkdownTree\\": "src/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  }
}

